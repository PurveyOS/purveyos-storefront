# Supabase Configuration for Migration Script
# Copy to .env and fill in your values from Supabase Dashboard

# Project URL (from Project Settings -> API)
SUPABASE_URL=https://your-project.supabase.co

# Service Role Key (from Project Settings -> API -> service_role key)
# WARNING: Keep this secret! Has admin privileges
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
